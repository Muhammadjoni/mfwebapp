# Application
APP_ENV=development
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mfwebapp
DB_USER=mfuser
DB_PASSWORD=mfpass
DB_SSL_MODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=5

# Postgres (docker-compose only)
POSTGRES_DB=mfwebapp
POSTGRES_USER=mfuser
POSTGRES_PASSWORD=mfpass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Security
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200
BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend
VITE_API_URL=http://localhost:8080/api/v1
